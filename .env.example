# Gwei 开发环境变量模板
# 使用方式：
#   1. 复制为 .env：cp .env.example .env
#   2. 修改 LLM_API_KEY 等敏感配置
#   3. docker compose up

# ===== 应用配置 =====
APP_NAME=gwei
DEBUG=true

# ===== 数据库连接（Docker 内部使用服务名）=====
# 开发环境 docker compose 会自动覆盖 DATABASE_URL 为 postgres:5432
DATABASE_URL=postgresql+asyncpg://gwei:gwei@localhost:5432/gwei
REDIS_URL=redis://localhost:6379/0

# ===== GitHub App 配置 =====
GITHUB_APP_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=0

# ===== LLM 配置 =====
LLM_PROVIDER=litellm
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# ===== 部署模式 =====
DEPLOYMENT_MODE=self-hosted