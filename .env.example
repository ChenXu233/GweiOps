# Gwei 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===== 应用配置 =====
APP_NAME=gwei
DEBUG=false

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://gwei:gwei@localhost:5432/gwei
REDIS_URL=redis://localhost:6379/0

# ===== GitHub App 配置 =====
# GitHub App ID（在 GitHub App 设置页面获取）
GITHUB_APP_ID=
# GitHub App 私钥（PEM 格式，从 GitHub App 设置页面下载）
GITHUB_PRIVATE_KEY=
# GitHub Webhook 密钥（在 GitHub App 设置页面配置 Webhook 时生成）
GITHUB_WEBHOOK_SECRET=
# GitHub App 安装 ID（安装 App 后从 URL 或 API 获取）
GITHUB_INSTALLATION_ID=0

# ===== LLM 配置 =====
# LLM 提供商（支持 litellm, openai, anthropic 等）
LLM_PROVIDER=litellm
# LLM API 密钥
LLM_API_KEY=
# LLM 模型名称
LLM_MODEL=gpt-4o

# ===== 部署配置 =====
# 部署模式：saas 或 self-hosted
DEPLOYMENT_MODE=saas
