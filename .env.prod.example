# Gwei 生产环境变量模板
# 使用方式：
#   1. 复制为 .env.prod：cp .env.prod.example .env.prod
#   2. 填写所有必填项
#   3. docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# 安全警告：
#   .env.prod 包含敏感信息，禁止提交到 Git！
#   生产环境建议使用 Docker Secrets 或 HashiCorp Vault

# ===== 应用配置 =====
APP_NAME=gwei
DEBUG=false

# ===== 数据库配置（必填）=====
# postgres 密码，必须修改
POSTGRES_PASSWORD=changeme_please

# ===== GitHub App 配置（必填）=====
GITHUB_APP_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=

# ===== LLM 配置（必填）=====
LLM_PROVIDER=litellm
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# ===== 部署版本（可选，默认为 latest）=====
# GWEI_VERSION=v0.1.0

# ===== 部署模式 =====
DEPLOYMENT_MODE=self-hosted