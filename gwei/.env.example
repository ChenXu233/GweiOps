# 既未 · Gwei - 环境变量配置
# 复制此文件为 .env 并填入你的配置

# 数据库
DATABASE_URL=postgresql+asyncpg://gwei:gwei@localhost:5432/gwei

# Redis
REDIS_URL=redis://localhost:6379/0

# 调试模式
DEBUG=true

# GitHub App 配置
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# LLM 配置
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# 部署模式 (saas 或 self-hosted)
DEPLOYMENT_MODE=self-hosted
